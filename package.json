{
  "name": "@shadow-library/scripts",
  "type": "module",
  "version": "0.2.2",
  "description": "Shared CLI for the Shadow Library ecosystem — centralizes the library build, local verification (lint + format + type-check + test), OpenAPI type generation, release, and migration-drift-check workflows behind a single .shadowrc.json config",
  "sideEffects": false,
  "bin": {
    "shadow": "dist/bin/shadow.js"
  },
  "scripts": {
    "prepare": "husky",
    "clean": "rm -rf dist logs CHANGELOG.md",
    "verify": "bun run scripts/verify.ts",
    "type-check": "tsc",
    "test": "bun test",
    "build": "bun run scripts/build.ts"
  },
  "engines": {
    "node": ">=23.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/shadow-library/scripts.git"
  },
  "author": "Leander Paul <leanderpaul97@outlook.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/shadow-library/scripts/issues"
  },
  "homepage": "https://github.com/shadow-library/scripts#readme",
  "dependencies": {
    "@commitlint/config-conventional": "^21.2.0",
    "@commitlint/format": "^21.2.0",
    "@commitlint/lint": "^21.2.0",
    "@commitlint/load": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@octokit/rest": "^22.0.1",
    "eslint": "^10.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-n": "^18.2.2",
    "eslint-plugin-perfectionist": "^5.10.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.9.5",
    "tsc-alias": "^1.9.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0"
  },
  "devDependencies": {
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@types/bun": "^1.3.14",
    "cssnano": "^8.0.2",
    "esbuild": "^0.28.1",
    "postcss": "^8.5.19",
    "postcss-import": "^16.1.1",
    "rollup": "^4.62.2",
    "rollup-plugin-banner2": "^1.3.1",
    "rollup-plugin-esbuild": "^6.2.1",
    "rollup-plugin-postcss": "^4.0.2"
  }
}
