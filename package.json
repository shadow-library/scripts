{
  "name": "@shadow-library/scripts",
  "type": "module",
  "version": "0.1.0",
  "description": "Shared CLI for the Shadow Library ecosystem — centralizes the library build, local verification, OpenAPI type generation, release, and migration-drift-check workflows duplicated across shadow-library/* repositories",
  "sideEffects": false,
  "bin": {
    "shadow-scripts": "bin/shadow-scripts"
  },
  "shadowLibrary": {
    "exports": {
      ".": "index"
    }
  },
  "scripts": {
    "prepare": "husky",
    "clean": "rm -rf dist logs CHANGELOG.md",
    "lint": "bun run scripts/lint.ts",
    "type-check": "bun run tsc",
    "test": "bun test",
    "build": "bun run scripts/build.ts"
  },
  "engines": {
    "node": ">=23.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/shadow-library/scripts.git"
  },
  "author": "Leander Paul <leanderpaul97@outlook.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/shadow-library/scripts/issues"
  },
  "homepage": "https://github.com/shadow-library/scripts#readme",
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@eslint/js": "^9.13.0",
    "@release-it/conventional-changelog": "^10.0.1",
    "@types/bun": "^1.1.13",
    "@typescript-eslint/parser": "^8.11.0",
    "eslint": "^9.13.0",
    "eslint-import-resolver-typescript": "^3.6.3",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-n": "^17.20.0",
    "globals": "^15.11.0",
    "husky": "^9.1.6",
    "prettier": "^3.3.3",
    "release-it": "^17.10.0",
    "tsc-alias": "^1.8.10",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.11.0"
  },
  "dependencies": {
    "openapi-typescript": "^7.4.1"
  }
}
